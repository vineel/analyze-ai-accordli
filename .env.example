# SoloMocky / Mocky local-dev environment template.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored and
# loaded by the Go API at startup (godotenv) and by the Makefile (which
# `include`s it for shell-side targets).
#
# Each block below maps to a Phase in solomocky-to-mocky-plan.md. Values are
# either `shared` (one team value, paste the same in every dev's .env) or
# `per-dev` (each developer has their own).
#
# Account-creation walkthroughs live in:
#   notes/claude-code-artifacts/phase-0-kickoff.md  (Track A)


# --------------------------------------------------------------------------
# Phase 0 — local Postgres + tunnel
# --------------------------------------------------------------------------

# Local Postgres 18 (brew). The API uses DATABASE_URL; reset_db.sh derives
# the database name from DB_NAME below.
DATABASE_URL=postgres://solomocky_app@localhost:5432/solomocky_dev?sslmode=disable
DB_NAME=solomocky_dev
DB_ROLE=solomocky_app

# Tailscale Funnel (per-dev).
# TUNNEL_HOSTNAME is your machine's public Funnel URL host portion, e.g.
# vineel-dev.accordli.ts.net. `make dev` echoes it; `make tunnel` doesn't
# read it (Tailscale derives the host from the local node).
TUNNEL_HOSTNAME=

# Optional. The API binds 0.0.0.0:8080 by default.
PORT=8080


# --------------------------------------------------------------------------
# Phase 1 — WorkOS identity (shared staging environment, per-dev webhook sig)
# --------------------------------------------------------------------------

# Shared across the team.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# Per-dev: each developer's tunnel hostname is registered as a separate
# webhook endpoint in the WorkOS dashboard, and each endpoint has its own
# signing secret.
WORKOS_WEBHOOK_SECRET=


# --------------------------------------------------------------------------
# Phase 4 — LLM (Anthropic direct; Foundry comes in Phase 8)
# --------------------------------------------------------------------------

# Vendor A and Vendor B both point at Anthropic for now (Phase 4 plan). We'll
# get distinct keys at Phase 4; today only ANTHRO_API_KEY is read.
ANTHRO_API_KEY=
ANTHRO_API_KEY_B=

# Helicone — dev workspace; full prompt/response bodies allowed in dev only.
HELICONE_API_KEY=


# --------------------------------------------------------------------------
# Phase 5 — Stripe (test mode)
# --------------------------------------------------------------------------

# Shared test-mode keys.
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_

# Webhook signing secret. The Stripe CLI (`stripe listen ...`) prints an
# ephemeral one on first run; a persistent dashboard endpoint pinned to the
# tunnel hostname has its own. Use whichever path you prefer.
STRIPE_WEBHOOK_SECRET=whsec_


# --------------------------------------------------------------------------
# Phase 6 — Observability + product analytics (dev project)
# --------------------------------------------------------------------------

POSTHOG_PROJECT_KEY=
POSTHOG_HOST=https://us.i.posthog.com


# --------------------------------------------------------------------------
# Phase 1 / 7 — Transactional email (sandbox server token)
# --------------------------------------------------------------------------

POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_ADDRESS=noreply@accordli-dev.local
