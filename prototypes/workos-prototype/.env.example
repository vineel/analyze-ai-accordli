# Copy to .env and fill in real values from your WorkOS dashboard.
# Never commit .env (already in .gitignore).

# From: WorkOS dashboard → Developer → API Keys
WORKOS_CLIENT_ID=client_01XXXXXXXXXXXXXXXXXXXXXXXX
WORKOS_API_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# From: WorkOS dashboard → Developer → Redirects (sign-in callback)
WORKOS_REDIRECT_URI=http://localhost:8080/auth/callback

# 32+ chars of random data; first 32 used as the AES-256 cookie-sealing key.
# Generate one yourself: `openssl rand -base64 32`
WORKOS_COOKIE_PASSWORD=replace-with-32-or-more-random-bytes-from-openssl-rand

# Where the backend redirects users after successful login.
FRONTEND_URL=http://localhost:5173
